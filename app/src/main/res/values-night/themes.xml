<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FitCore" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/accent_dark</item>
        <item name="colorOnPrimaryContainer">@color/black</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="NavTextActive">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/nav_active</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NavTextInactive">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/nav_inactive</item>
    </style>

    <style name="TimePickerTheme" parent="ThemeOverlay.Material3.Dark">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/surface</item>
    </style>

    <style name="DialogTheme" parent="ThemeOverlay.Material3.Dark">
        <item name="android:background">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:windowBackground">@color/surface</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
    </style>
</resources>