<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card"
    android:padding="20dp"
    android:minWidth="280dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="保存运动"
        android:textColor="@color/accent"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="运动感受"
        android:textColor="#FF999999"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/feel_bad" android:layout_width="0dp"
            android:layout_height="44dp" android:layout_weight="1" android:layout_marginEnd="3dp"
            android:gravity="center" android:text="😫\n差" android:textColor="#FF888888"
            android:textSize="12sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/feel_poor" android:layout_width="0dp"
            android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="😕\n较差"
            android:textColor="#FF888888" android:textSize="12sp"
            android:background="@drawable/bg_card" android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/feel_ok" android:layout_width="0dp"
            android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="😐\n一般"
            android:textColor="#FF888888" android:textSize="12sp"
            android:background="@drawable/bg_card" android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/feel_good" android:layout_width="0dp"
            android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="😊\n良好"
            android:textColor="#FF888888" android:textSize="12sp"
            android:background="@drawable/bg_card" android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/feel_great" android:layout_width="0dp"
            android:layout_height="44dp" android:layout_weight="1" android:layout_marginStart="3dp"
            android:gravity="center" android:text="🔥\n爽" android:textColor="#FF888888"
            android:textSize="12sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_cal_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="预计消耗 -- 千卡"
        android:textColor="@color/accent"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/et_notes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:hint="备注（可选）"
        android:paddingHorizontal="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView android:id="@+id/btn_discard" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="8dp"
            android:gravity="center" android:text="丢弃" android:textColor="@color/text_secondary"
            android:textSize="14sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />

        <TextView android:id="@+id/btn_save" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="8dp"
            android:gravity="center" android:text="保存" android:textColor="@color/black"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/bg_accent_btn"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>
</LinearLayout>
