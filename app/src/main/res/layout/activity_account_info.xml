<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <!-- 用户图标 -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_gender" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="账号信息"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 用户名 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="用户名"
            android:textColor="#FF999999"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp" android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_myplaces"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/tv_account_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="username"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 密码 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="密码"
            android:textColor="#FF999999"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="18dp" android:layout_height="18dp"
                android:src="@android:drawable/ic_lock_idle_lock"
                android:alpha="0.5" />

            <TextView
                android:id="@+id/tv_account_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:text="••••••••"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- 修改密码按钮 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_change_pwd"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_outline_btn"
            android:text="修改密码"
            android:textColor="@color/accent"
            android:textSize="14sp" />

        <!-- 退出登录 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_outline_btn"
            android:text="退出登录"
            android:textColor="@color/error"
            android:textSize="14sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="0.6" />

    </LinearLayout>
</ScrollView>

    <include layout="@layout/watermark_bg" />

</FrameLayout>
