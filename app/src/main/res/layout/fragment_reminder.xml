<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="20dp"
    android:paddingTop="80dp">

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.25" />

    <!-- 闹钟图标 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰"
        android:textSize="72sp"
        android:alpha="0.3" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="运动提醒"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="设置时间提醒你锻炼"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tv_time_display"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="07:00"
        android:textColor="@color/accent"
        android:textSize="46sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="提醒时间"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_time_picker"
            android:layout_width="120dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_outline_btn"
            android:text="设置时间"
            android:textColor="@color/accent"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 提醒模式选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="提醒方式"
        android:textColor="#FF999999"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_toggle"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/mode_once"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="响一次"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_toggle_active"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/mode_custom"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="自定义"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 星期选择（默认隐藏） -->
    <LinearLayout
        android:id="@+id/layout_days"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView android:id="@+id/day_mon" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="3dp"
            android:gravity="center" android:text="一" android:textColor="#FF888888"
            android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_tue" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="二"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_wed" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="三"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_thu" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="四"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_fri" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="五"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_sat" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp" android:gravity="center" android:text="六"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
        <TextView android:id="@+id/day_sun" android:layout_width="0dp"
            android:layout_height="40dp" android:layout_weight="1" android:layout_marginStart="3dp"
            android:gravity="center" android:text="日"
            android:textColor="#FF888888" android:textSize="13sp" android:background="@drawable/bg_card"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="开启提醒"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_reminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:thumbTint="@color/accent"
            android:trackTint="@color/border" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_test_notify"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_outline_btn"
        android:text="测试通知（立刻发送一条提醒）"
        android:textColor="@color/accent"
        android:textSize="13sp" />

    <!-- 底部装饰 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:orientation="vertical">

        <View
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="@color/border" />

        <TextView
            android:id="@+id/tv_quote1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="千里之行，始于足下"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:alpha="0.55" />

        <TextView
            android:id="@+id/tv_quote2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="坚持锻炼，成就更好的自己"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:alpha="0.4" />
    </LinearLayout>

    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="0.6" />

</LinearLayout>

    <include layout="@layout/watermark_bg" />

</FrameLayout>
