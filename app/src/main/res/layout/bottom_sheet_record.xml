<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingTop="20dp"
    android:paddingBottom="24dp"
    android:paddingHorizontal="20dp">

    <!-- 拖拽条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_chip" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/bs_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="记录 跑步"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- 时长 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="运动时长"
        android:textColor="#FF999999"
        android:textSize="14sp" />

    <NumberPicker
        android:id="@+id/np_minutes"
        android:layout_width="wrap_content"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:theme="@style/NumberPickerTheme" />

    <!-- 感受 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="运动感受"
        android:textColor="#FF999999"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/feeling_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/feel_bad"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="3dp"
            android:gravity="center"
            android:text="😫\n差"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/feel_poor"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"
            android:text="😕\n较差"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/feel_ok"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"
            android:text="😐\n一般"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/feel_good"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:gravity="center"
            android:text="😊\n良好"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/feel_great"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="3dp"
            android:gravity="center"
            android:text="🔥\n爽"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- 卡路里 -->
    <TextView
        android:id="@+id/bs_calories"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="预计消耗 300 千卡"
        android:textColor="@color/accent"
        android:textSize="14sp" />

    <!-- 备注 -->
    <EditText
        android:id="@+id/bs_notes"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:hint="添加备注（可选）"
        android:paddingHorizontal="14dp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="14sp" />

    <!-- 记录方式选择 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="选择记录方式"
        android:textColor="@color/accent"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <!-- 方式一：计时运动 -->
        <LinearLayout
            android:id="@+id/btn_start_timer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_card"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⏱ 计时运动" android:textColor="@color/text_primary"
                    android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="还没开始，点击开始实时计时"
                    android:textColor="@color/text_tertiary" android:textSize="12sp" />
            </LinearLayout>

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_media_play"
                android:tint="@color/accent" android:alpha="0.6" />
        </LinearLayout>

        <!-- 方式二：快速记录 -->
        <LinearLayout
            android:id="@+id/btn_save_record"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_card_accent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="📝 快速记录" android:textColor="@color/accent"
                    android:textSize="15sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp" android:text="已经完成，直接填写信息保存"
                    android:textColor="@color/text_tertiary" android:textSize="12sp" />
            </LinearLayout>

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_upload"
                android:tint="@color/accent" android:alpha="0.6" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
