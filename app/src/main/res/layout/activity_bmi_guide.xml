<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="BMI 指南"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- 用户 BMI -->
        <LinearLayout
            android:id="@+id/layout_user_bmi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card_accent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的 BMI"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_user_bmi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="--"
                android:textColor="@color/text_primary"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_user_advice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="请先填写身高体重"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 介绍 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="BMI 介绍"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="身体质量指数（BMI），是国际上常用的衡量人体胖瘦程度以及是否健康的一个标准。计算公式为：\nBMI = 体重(kg) ÷ 身高²(m²)"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp" />

        <!-- 亚洲标准表格 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="亚洲 BMI 对照表"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="4dp">

            <!-- 表头 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/surface_variant"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <TextView android:layout_width="0dp" android:layout_weight="1.5"
                    android:layout_height="wrap_content" android:text="分级"
                    android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="BMI范围"
                    android:textColor="@color/accent" android:textSize="13sp" android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/border_light" />

            <!-- 偏瘦 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1.5"
                    android:layout_height="wrap_content" android:text="偏瘦"
                    android:textColor="#FF4488FF" android:textSize="13sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="&lt; 18.5"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginHorizontal="12dp" android:background="@color/border_light" />

            <!-- 正常 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1.5"
                    android:layout_height="wrap_content" android:text="正常"
                    android:textColor="#FF44DD44" android:textSize="13sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="18.5 - 22.9"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginHorizontal="12dp" android:background="@color/border_light" />

            <!-- 偏重 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1.5"
                    android:layout_height="wrap_content" android:text="偏重"
                    android:textColor="#FFFFAA00" android:textSize="13sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="23.0 - 27.4"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginHorizontal="12dp" android:background="@color/border_light" />

            <!-- 肥胖 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp"
                android:gravity="center_vertical" android:orientation="horizontal"
                android:paddingHorizontal="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1.5"
                    android:layout_height="wrap_content" android:text="肥胖"
                    android:textColor="#FFFF4444" android:textSize="13sp" />
                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="≥ 27.5"
                    android:textColor="@color/text_primary" android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 健康建议 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="健康建议"
            android:textColor="@color/accent"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="偏瘦 (&lt; 18.5)"
                android:textColor="#FF4488FF"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="体重过轻可能影响健康，建议增加营养摄入，适当增重。"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginTop="10dp" android:background="@color/border_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="正常 (18.5 - 22.9)"
                android:textColor="#FF44DD44"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="体重处于健康范围，建议保持当前体重和健康的生活方式。"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginTop="10dp" android:background="@color/border_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="偏重 (23.0 - 27.4)"
                android:textColor="#FFFFAA00"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="体重略高，建议通过合理饮食和适量运动来减重。"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:layout_marginTop="10dp" android:background="@color/border_light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="肥胖 (≥ 27.5)"
                android:textColor="#FFFF4444"
                android:textSize="13sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="体重过高，建议咨询医生或营养师制定减重计划。"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="24dp" />

    </LinearLayout>
</ScrollView>

    <include layout="@layout/watermark_bg" />

</FrameLayout>
