<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 类型输入 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:paddingHorizontal="14dp"
        android:paddingVertical="2dp">

        <ImageView
            android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_flame"
            android:alpha="0.6" />

        <EditText
            android:id="@+id/et_workout_type"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="运动类型（如：跑步、深蹲...）"
            android:textColorHint="@color/text_muted"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- 计时圆环 -->
    <FrameLayout
        android:layout_width="220dp"
        android:layout_height="220dp">

        <View
            android:layout_width="220dp" android:layout_height="220dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_timer_ring" />

        <View
            android:layout_width="200dp" android:layout_height="200dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_timer_inner" />

        <LinearLayout
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_timer"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/accent" android:textSize="34sp"
                android:textStyle="bold" android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tv_timer_status"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="2dp" android:text="准备开始"
                android:textColor="@color/text_secondary" android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- 三按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_done"
            android:layout_width="64dp" android:layout_height="64dp"
            android:layout_marginEnd="24dp"
            android:backgroundTint="@color/surface_variant"
            android:src="@android:drawable/ic_menu_upload"
            app:tint="@color/accent"
            app:maxImageSize="28dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_play"
            android:layout_width="80dp" android:layout_height="80dp"
            android:backgroundTint="@color/accent"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/black"
            app:maxImageSize="36dp" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_cancel"
            android:layout_width="64dp" android:layout_height="64dp"
            android:layout_marginStart="24dp"
            android:backgroundTint="@color/surface_variant"
            android:src="@android:drawable/ic_delete"
            app:tint="@color/error"
            app:maxImageSize="28dp" />
    </LinearLayout>
</LinearLayout>

    <include layout="@layout/watermark_bg" />

</FrameLayout>
