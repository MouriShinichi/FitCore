<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="个人中心"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- ===== 头图背景区 ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <!-- 自定义背景图（撑满整个上部区域） -->
            <ImageView
                android:id="@+id/iv_profile_background"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="个人背景" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人中心"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- 头像区 -->
                <FrameLayout
                    android:id="@+id/layout_profile_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- 虚化背景层 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:background="@drawable/bg_avatar_area" />

                    <!-- 虚影文字 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:text="FITCORE"
                        android:textColor="@color/accent"
                        android:textSize="52sp"
                        android:textStyle="bold"
                        android:alpha="0.08"
                        android:letterSpacing="0.5"
                        android:maxLines="1"
                        android:ellipsize="none"
                        android:scrollHorizontally="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="点击更换头像" />

            <TextView
                android:id="@+id/tv_profile_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="用户"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

            <!-- 背景编辑图标 -->
            <ImageView
                android:id="@+id/iv_bg_edit"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="#CCFFFFFF"
                android:alpha="0.6"
                android:padding="4dp"
                android:background="@drawable/bg_bg_edit_badge"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="更换背景" />

        </FrameLayout>

        </LinearLayout>
        </FrameLayout>

        <!-- ===== 个人信息 2×2 矩形卡片 ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="个人信息"
            android:textColor="@color/accent"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <!-- 性别卡片 -->
            <FrameLayout
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="5dp"
                android:background="@drawable/bg_card">

                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="top|end" android:layout_margin="10dp"
                    android:src="@drawable/ic_gender" android:alpha="0.5" />

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_info_gender"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="未填写" android:textColor="@color/text_primary"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="GENDER" android:textColor="@color/text_tertiary"
                        android:textSize="10sp" android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>

            <!-- 年龄卡片 -->
            <FrameLayout
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="5dp"
                android:background="@drawable/bg_card">

                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="top|end" android:layout_margin="10dp"
                    android:src="@drawable/ic_age" android:alpha="0.5" />

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_info_age"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="未填写" android:textColor="@color/text_primary"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="AGE" android:textColor="@color/text_tertiary"
                        android:textSize="10sp" android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <!-- 身高卡片 -->
            <FrameLayout
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginEnd="5dp"
                android:background="@drawable/bg_card">

                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="top|end" android:layout_margin="10dp"
                    android:src="@drawable/ic_height" android:alpha="0.5" />

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_info_height"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="未填写" android:textColor="@color/text_primary"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="HEIGHT" android:textColor="@color/text_tertiary"
                        android:textSize="10sp" android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>

            <!-- 体重卡片 -->
            <FrameLayout
                android:layout_width="0dp" android:layout_height="90dp"
                android:layout_weight="1" android:layout_marginStart="5dp"
                android:background="@drawable/bg_card">

                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:layout_gravity="top|end" android:layout_margin="10dp"
                    android:src="@drawable/ic_weight" android:alpha="0.5" />

                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="match_parent" android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_info_weight"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="未填写" android:textColor="@color/text_primary"
                        android:textSize="18sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"
                        android:text="WEIGHT" android:textColor="@color/text_tertiary"
                        android:textSize="10sp" android:letterSpacing="0.1" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ===== BMI 卡片 ===== -->
        <LinearLayout
            android:id="@+id/card_bmi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BMI 身体质量指数"
                    android:textColor="@color/accent"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bmi_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="--"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bmi_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="请填写身高体重"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- BMI 刻度条 -->
            <LinearLayout
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginEnd="0dp"
                android:orientation="vertical">

                <!-- 色条 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="28dp"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <View android:id="@+id/bmi_bar_under" android:layout_width="0dp"
                        android:layout_height="28dp" android:layout_weight="18.5"
                        android:background="#FF4488FF" android:alpha="0.4" />
                    <View android:id="@+id/bmi_bar_normal" android:layout_width="0dp"
                        android:layout_height="28dp" android:layout_weight="5.5"
                        android:background="#FF44DD44" android:alpha="0.4" />
                    <View android:id="@+id/bmi_bar_over" android:layout_width="0dp"
                        android:layout_height="28dp" android:layout_weight="4"
                        android:background="#FFFFAA00" android:alpha="0.4" />
                    <View android:id="@+id/bmi_bar_obese" android:layout_width="0dp"
                        android:layout_height="28dp" android:layout_weight="6"
                        android:background="#FFFF4444" android:alpha="0.4" />
                </LinearLayout>

                <!-- 标签 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:orientation="horizontal">

                    <TextView android:layout_width="0dp" android:layout_weight="18.5"
                        android:layout_height="wrap_content" android:text="偏瘦"
                        android:textSize="12sp" android:gravity="center"
                        android:textColor="#FF4488FF" android:alpha="0.7" />
                    <TextView android:layout_width="0dp" android:layout_weight="5.5"
                        android:layout_height="wrap_content" android:text="正常"
                        android:textSize="12sp" android:gravity="center"
                        android:textColor="#FF44DD44" android:alpha="0.7" />
                    <TextView android:layout_width="0dp" android:layout_weight="4"
                        android:layout_height="wrap_content" android:text="偏胖"
                        android:textSize="12sp" android:gravity="center"
                        android:textColor="#FFFFAA00" android:alpha="0.7" />
                    <TextView android:layout_width="0dp"
                        android:layout_height="wrap_content" android:text="肥胖"
                        android:layout_weight="6"
                        android:textSize="12sp" android:gravity="center"
                        android:textColor="#FFFF4444" android:alpha="0.7" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ===== 信息操作 ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="14dp"
                android:text="信息操作"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btn_edit_profile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_edit" />

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="编辑资料"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="90"
                    android:alpha="0.3" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border_light" />

            <LinearLayout
                android:id="@+id/btn_calorie_guide"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_flame"
                    android:tint="@color/accent" />

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="消耗计算"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="90"
                    android:alpha="0.3" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border_light" />

            <LinearLayout
                android:id="@+id/btn_bmi_guide"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_weight"
                    android:tint="@color/accent" />

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="BMI建议"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="90"
                    android:alpha="0.3" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border_light" />

            <LinearLayout
                android:id="@+id/btn_account_info"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    android:tint="@color/accent" />

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="账号信息"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="16dp" android:layout_height="28dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="90"
                    android:alpha="0.3" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginHorizontal="16dp"
                android:background="@color/border_light" />

            <LinearLayout
                android:id="@+id/btn_history"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_history" />

                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="运动记录"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="90"
                    android:alpha="0.3" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="28dp" />

    </LinearLayout>
</ScrollView>

    <include layout="@layout/watermark_bg" />

</FrameLayout>
